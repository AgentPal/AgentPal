{
  "schema": "agentpal.team-pack.v0.6",
  "type": "team-pack",
  "team_id": "marketing-growth-team",
  "display_name": "Marketing Growth Team",
  "version": "0.6.0",
  "status": "draft",
  "description": "A public-safe Team Pack example for AgentPal promotion themes, copy, visual briefs, publishing plans, and performance retrospectives.",
  "discoverable": true,
  "contactable": true,
  "team_modes": ["consult", "delegate", "joint_work", "review"],
  "default_owner_role": "team-conductor",
  "default_entry_pal": "mira-main",
  "supported_task_types": [
    "promotion-content-planning",
    "weekly-content-calendar",
    "promotion-copywriting",
    "visual-requirement-brief",
    "publishing-plan",
    "campaign-retrospective"
  ],
  "forbidden_task_types": [
    "automatic-content-publication",
    "paid-ad-account-operation",
    "business-process-discovery-primary",
    "code-implementation",
    "final-release-verification",
    "private-customer-data-analysis"
  ],
  "asset_priority": {
    "team_workflow_priority": "high",
    "team_eval_priority": "high",
    "team_assets_override_pal_assets": false,
    "pal_boundary_overrides_team_role": true
  },
  "collaboration_policy": {
    "selection_requires_ai_judgement": true,
    "keyword_routing_allowed": false,
    "copy_pal_assets_into_team": false,
    "copy_team_pack_to_external_project": false
  },
  "memory_policy": {
    "team_memory_enabled": true,
    "private_memory_allowed_in_public_pack": false,
    "writeback_requires_review": true,
    "external_project_memory_write_default": false
  },
  "eval_policy": {
    "team_eval_required_for_team_tasks": true,
    "definition_of_done": "evals/definition-of-done.md",
    "quality_gates": [
      "campaign-goal-stated",
      "audience-and-channel-stated",
      "topic-rationale-stated",
      "copy-and-visual-brief-linked",
      "publishing-plan-separated-from-actual-publication",
      "retrospective-decision-recorded"
    ]
  },
  "entry": {
    "team": "TEAM.md",
    "roster": "roster.json",
    "contacts": "TEAM_CONTACTS.md",
    "resource_index": "RESOURCE_INDEX.md"
  },
  "asset_dirs": {
    "roles": "roles/",
    "knowledge": "knowledge/",
    "skills": "skills/",
    "workflows": "workflows/",
    "runbooks": "runbooks/",
    "memory": "memory/",
    "evals": "evals/",
    "routing": "routing/",
    "reports": "reports/"
  }
}
