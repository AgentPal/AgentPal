    "source_pal_json": "official/pals/PalSmith-pal-governor/pal.json",
    "real_writeback_allowed": false,
    "official_pal_file_modified": false,
    "real_asset_manifest_generated": false
  },
  "entry": {
    "pal": "PAL.md",
    "readme": "README.md",
    "agent": "AGENTS.md",
    "skill": "SKILL.md",
    "asset_manifest": "asset-manifest.json"
  },
  "asset_dirs": {
    "checklists": "checklists/",
    "core": "core/",
    "evals": "evals/",
    "examples": "examples/",
    "governance": "governance/",
    "identity": "identity/",
    "knowledge": "knowledge/",
    "memory": "memory/",
    "reports": "reports/",
    "research": "research/",
    "runbooks": "runbooks/",
    "skills": "skills/",
    "state": "state/",
    "templates": "templates/",
    "workflows": "workflows/"
  },
  "core_capabilities": [
    "Pal Pack classification",
    "Pal creation planning",
    "Pal team design planning",
    "Pal asset health review",
    "job fitness inspection",
    "content preservation planning",
    "web research to knowledge planning",
    "import staging review",
    "clean export planning",
    "with-memory export risk review",
    "version governance planning",
    "readiness review",
    "registry and contacts update proposals"
  ],
  "collaboration": {
    "discoverable": true,
    "contactable": true,
    "allowed_modes": [
      "consult",
      "delegate",
      "handoff",
      "joint_work"
    ],
    "requires_user_approval_for_sensitive_context": true,
    "central_roster_required": true
  },
  "discovery": {
    "direct_call": "/pal PalSmith",
    "aliases": [
      "PalSmith",
      "palsmith",
      "Pal Smith"
    ],
    "central_roster_ref": "workspace/organization/contacts/pals.json",
    "source_of_truth": "central_roster"
  },
  "runtime_awareness": {
    "requires_runtime_evidence": true,
    "pal_executes_runtime_actions": false,
    "auto_probe_runtime": false
  },
  "capability_inventory_refs": [
    {
      "ref": "workspace/organization/capability-inventory/",
      "purpose": "AI judgement input only when task-relevant",
      "judgement_input_only": true
    }
  ],
  "pal_skill_boundary": {
    "pal_skills_are_role_level": true,
    "agent_skills_are_runtime_level": true,
    "pal_skills_dir_default": "skills/",
    "agent_skill_refs_are_references_only": true
  },
  "agent_skill_refs_policy": {
    "agent_skill_refs_are_references_only": true,
    "store_agent_skills_in_pal_skills_by_default": false,
    "requires_runtime_evidence": true
  },
  "memory_policy": {
    "private_memory_allowed_in_public_pack": false,
    "task_logs_allowed_in_pal_json": false,
    "large_report_bodies_allowed_in_pal_json": false,
    "memory_write_requires_approval": true
  },
  "external_project_write_policy": {
    "external_project_write_allowed_by_default": false,
    "copy_pal_assets_to_external_project_by_default": false,
    "thin_binding_required": true
  },
  "no_keyword_routing_policy": {
    "keyword_routing_allowed": false,
    "domain_routing_allowed": false,
    "role_routing_allowed": false,
    "route_maps_allowed": false
  },
  "credentials_allowed": false,
  "palsmith_governance_boundary": {
    "can_classify_create_and_upgrade_pal_assets_as_no_code_governance": true,
    "can_propose_central_roster_changes": true,
    "can_automatically_modify_central_roster": false,
    "can_default_write_central_pal_assets_into_external_projects": false,
    "can_create_connector_scanner_or_auto_execution": false
  },
  "compatibility": {
    "legacy_v0_1_readable": true,
    "asset_manifest_required": false,
    "directory_convention_fallback": true,
    "missing_asset_manifest_is_upgrade_gap": true,
    "missing_optional_asset_dirs": [
      "learning"
    ],
    "human_review_required_before_real_write": true
  },
  "human_review_required": [
    "governance capability wording",
    "official registration and contacts proposal wording",
    "version value for real metadata update",
    "whether future asset_manifest entry should be written before real manifest exists",
    "whether missing optional learning directory should be not-applicable or a future gap"
  ],
  "fields_not_proposed": [
    "central roster edits",
    "real asset manifest content",
    "external project local Pal asset copies",
    "runtime execution results",
    "private memory",
    "large report bodies"
  ],
  "forbidden_defaults": [
    "automatic roster modification",
    "connector creation",
    "scanner creation",
    "auto execution",
    "external project Pal asset copying",
    "credential storage",
    "Agent Skill files stored as Pal Skills"
  ],
  "migration_notes": [
    "Dry-run proposal only; do not write this file over the real official PalSmith pal.json in R112.",
    "PalSmith can classify, create, and upgrade Pal assets as no-code governance work through proposals and Runtime Task Packages.",
    "PalSmith cannot automatically modify the central roster, cannot default-write central Pal assets into external projects, and cannot create connector, scanner, or auto-execution behavior.",
    "No real official asset-manifest.json is generated by this proposal."
  ]
}

